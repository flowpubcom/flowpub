# FlowPub — variables de entorno. Copia a .env.local y rellena.
# Recuerda: NEXT_PUBLIC_* se hornea en el bundle PÚBLICO → solo valores públicos.

# ── Supabase (públicas) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (SECRETO — solo servidor, NUNCA NEXT_PUBLIC) ──
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Gemini (SECRETO — STT, pulido, traducción) ──
GEMINI_API_KEY=

# ── Cloudflare Turnstile ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Resend (correo) ──
RESEND_API_KEY=

# ── App ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth NO va aquí: se configura en el dashboard de Supabase
# (Authentication → Providers → Google) con el Client ID/Secret de Google Cloud.
